{
  "version": 3,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 19,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": "debug",
      "displayName": "Debug",
      "description": "Configure a Debug build with symbols and no optimization.",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "release",
      "displayName": "Release",
      "description": "Configure a Release build with full optimization.",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "relwithdebinfo",
      "displayName": "RelWithDebInfo",
      "description": "Configure an optimized build with debug information.",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo"
      }
    },
    {
      "name": "asan",
      "displayName": "AddressSanitizer",
      "description": "Configure a custom ASan build type for memory error detection.",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Asan"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "debug",
      "displayName": "Build Debug",
      "description": "Build the Debug preset.",
      "configurePreset": "debug"
    },
    {
      "name": "release",
      "displayName": "Build Release",
      "description": "Build the Release preset.",
      "configurePreset": "release"
    },
    {
      "name": "relwithdebinfo",
      "displayName": "Build RelWithDebInfo",
      "description": "Build the RelWithDebInfo preset.",
      "configurePreset": "relwithdebinfo"
    },
    {
      "name": "asan",
      "displayName": "Build ASan",
      "description": "Build the AddressSanitizer preset.",
      "configurePreset": "asan"
    }
  ]
}
